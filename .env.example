APP_NAME=Agentes IA Studio
APP_ENV=development
SECRET_KEY=troque-esta-chave
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/agentes_ia

# OpenAI API Key - Para geração de roteiros
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Tavily API Key - Para pesquisa de conteúdo
# Obtenha em: https://tavily.com/
TAVILY_API_KEY=

# Perplexity API Key - Alternativa para pesquisa de conteúdo
# Obtenha em: https://www.perplexity.ai/
PERPLEXITY_API_KEY=

# Shotstack API - Para geração de vídeos
# IMPORTANTE: Sem estas chaves, o sistema funcionará em MODO DEMONSTRAÇÃO
# com vídeos de exemplo, mas não gerará vídeos reais customizados.
#
# Para obter suas chaves:
# 1. Acesse: https://dashboard.shotstack.io/register
# 2. Crie uma conta gratuita
# 3. No dashboard, vá em API Keys
# 4. Copie sua API Key (começa com "sk_")
# 5. Opcional: copie seu Owner ID se estiver usando templates com merge
#
# Exemplo:
# SHOTSTACK_API_KEY=sk_test_1234567890abcdef
# SHOTSTACK_OWNER_ID=abc123def456
# SHOTSTACK_ENV=stage  # use "production" para chaves live
VIDEO_PROVIDER=shotstack
SHOTSTACK_API_KEY=
SHOTSTACK_OWNER_ID=
SHOTSTACK_ENV=stage

# Gemini / Veo - Para geração vertical com imagem-guia e vídeo nativo
# Use VIDEO_PROVIDER=veo para habilitar este fluxo.
# Gere sua chave em: https://aistudio.google.com/apikey
# O provider Veo usa chave de API, não login e senha interativos.
# Exemplos:
# VIDEO_PROVIDER=veo
# GEMINI_API_KEY=AIza...
# VEO_MODEL=veo-3.1-generate-preview
# VEO_ASPECT_RATIO=9:16
# VEO_RESOLUTION=720p
# VEO_DURATION_SECONDS=8
# GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
GEMINI_API_KEY=
VEO_MODEL=veo-3.1-generate-preview
VEO_ASPECT_RATIO=9:16
VEO_RESOLUTION=720p
VEO_DURATION_SECONDS=8
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Flags opcionais para smoke controlado de integrações externas
# RUN_EXTERNAL_API_SMOKE=1
# EXTERNAL_API_SMOKE_ALLOW_SHOTSTACK_RENDER=0

